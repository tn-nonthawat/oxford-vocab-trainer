# .dockerignore  –  Files excluded from the Docker build context

# Python bytecode
__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
env/
.venv/

# Secrets & local database (never bake these into the image)
.secret_key
*.db
*.sqlite3
.env
.env.*

# Git history
.git/
.gitignore

# Windows scripts (not needed on the server)
*.bat

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/
