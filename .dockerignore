# .dockerignore  –  Files excluded from the Docker build context

# Python bytecode
__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
env/
.venv/

# Secrets & local database (never bake these into the image)
.secret_key
*.db
*.sqlite3
.env
.env.*

# Git history
.git/
.gitignore

# Windows scripts (not needed on the server)
*.bat

# React — node_modules are installed inside the Docker build (Stage 1),
# so we never need to send the local copy to the build context.
dashboard-react/node_modules/
dashboard-react/dist/

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/
